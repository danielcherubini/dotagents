{
  "lastChangelogVersion": "0.80.3",
  "defaultProvider": "tama",
  "defaultModel": "whatevers-hot-n-fresh",
  "packages": [
    "npm:pi-web-access",
    "npm:pi-updater",
    "npm:pi-dracula",
    "npm:pi-provider-tama",
    "npm:pi-mcp-adapter"
  ],
  "defaultThinkingLevel": "medium",
  "theme": "dracula",
  "hideThinkingBlock": false,
  "quietStartup": false,
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "treeFilterMode": "no-tools",
  "terminal": {
    "showTerminalProgress": false
  },
  "enabledModels": [
    "openrouter/minimax/minimax-m3",
    "openrouter/z-ai/glm-5.2",
    "tama/gotta-go-fast",
    "tama/whatevers-hot-n-fresh"
  ],
  "archimedes.notify": {
    "enabled": true,
    "notifyOnAgentEnd": true,
    "notifyOnQuestion": true,
    "delayMs": 30000
  }
}